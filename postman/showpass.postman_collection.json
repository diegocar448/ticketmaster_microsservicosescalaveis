            "url": { "raw": "{{gateway_url}}/events/{{event_slug}}/public", "host": ["{{gateway_url}}"], "path": ["events", "{{event_slug}}", "public"] }
          }
        },
        {
          "name": "GET /events/:id/public-meta (interno)",
