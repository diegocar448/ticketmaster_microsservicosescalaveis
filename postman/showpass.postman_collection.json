                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{organizer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"venueId\": \"{{venue_id}}\",\n  \"categoryId\": \"{{category_id}}\",\n  \"title\": \"Rock in Rio 2025\",\n  \"description\": \"Festival de rock em formato tradicional — headliners internacionais.\",\n  \"startAt\": \"2025-09-13T19:00:00.000Z\",\n  \"endAt\": \"2025-09-13T23:59:00.000Z\",\n  \"imageUrl\": \"https://example.com/rock-in-rio.jpg\"\n}"
            },
            "url": { "raw": "{{gateway_url}}/events", "host": ["{{gateway_url}}"], "path": ["events"] }
          }
        },
        {
          "name": "GET /events (organizer) — lista",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{organizer_token}}" }],
            "url": {
              "raw": "{{gateway_url}}/events?page=1&limit=20",
              "host": ["{{gateway_url}}"],
              "path": ["events"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "on_sale", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "GET /events/:id (organizer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{organizer_token}}" }],
            "url": { "raw": "{{gateway_url}}/events/{{event_id}}", "host": ["{{gateway_url}}"], "path": ["events", "{{event_id}}"] }
          }
        },
        {
          "name": "PATCH /events/:id/status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{organizer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"on_sale\"\n}"
            },
            "description": "Transições válidas: published, on_sale, sold_out, cancelled, completed. draft NÃO é permitido via API.",
            "url": { "raw": "{{gateway_url}}/events/{{event_id}}/status", "host": ["{{gateway_url}}"], "path": ["events", "{{event_id}}", "status"] }
          }
        },
        {
          "name": "GET /events/:slug/public (público)",
          "request": {
            "method": "GET",
            "header": [],
