            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Diego\",\n  \"email\": \"diego@email.com\",\n  \"password\": \"MinhaSenha@123\"\n}"
            },
            "url": { "raw": "{{gateway_url}}/auth/buyers/register", "host": ["{{gateway_url}}"], "path": ["auth", "buyers", "register"] }
          }
        },
        {
          "name": "POST /auth/buyers/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) {",
                  "    pm.collectionVariables.set('buyer_token', json.accessToken);",
                  "    console.log('Buyer token salvo');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"diego@email.com\",\n  \"password\": \"MinhaSenha@123\"\n}"
            },
            "url": { "raw": "{{gateway_url}}/auth/buyers/login", "host": ["{{gateway_url}}"], "path": ["auth", "buyers", "login"] }
          }
        },
        {
          "name": "POST /auth/buyer/login (legado)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"diego@email.com\",\n  \"password\": \"MinhaSenha@123\"\n}"
            },
            "description": "Rota legada — prefira /auth/buyers/login.",
            "url": { "raw": "{{gateway_url}}/auth/buyer/login", "host": ["{{gateway_url}}"], "path": ["auth", "buyer", "login"] }
          }
        }
      ]
    },
