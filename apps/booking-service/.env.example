# apps/booking-service/.env.example
# Copie para .env e preencha os valores

# ── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004
SERVICE_NAME=booking-service

# ── Banco de dados (database próprio do serviço) ─────────────────────────────
DATABASE_URL="postgresql://booking_svc:booking_svc_dev@localhost:5432/showpass_booking"

# ── JWT (chave pública — apenas verificação) ─────────────────────────────────
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Redis (CRÍTICO — locks distribuídos para anti-double-booking) ────────────
# Este serviço depende do Redis para funcionar corretamente.
# Se o Redis estiver indisponível, o Circuit Breaker rejeita reservas com mensagem amigável.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_secret
SEAT_LOCK_TTL_SECONDS=420  # 7 minutos — janela de checkout

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=booking-service
KAFKA_GROUP_ID=booking-service-group

# ── gRPC — comunicação com event-service ─────────────────────────────────────
EVENT_SERVICE_GRPC_URL=event-service:50051

# ── Observabilidade ──────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=booking-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
