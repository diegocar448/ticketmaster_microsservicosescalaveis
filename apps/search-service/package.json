{
  "name": "@showpass/search-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node --watch --conditions=development --loader @swc-node/register/esm src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test:e2e": "jest --config test/jest-e2e.json"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/elasticsearch": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@showpass/kafka": "workspace:*",
    "@showpass/types": "workspace:*",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@swc-node/register": "^1.10.0",
    "@types/node": "^22.0.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.0.0"
