# apps/search-service/.env.example
# Copie para .env e preencha os valores

# ── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3006
SERVICE_NAME=search-service

# ── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
# Em produção: usar autenticação com usuário/senha ou API key
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=...

# ── JWT (chave pública — apenas verificação) ─────────────────────────────────
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Kafka (consumer: CDC events do Debezium) ─────────────────────────────────
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=search-service
KAFKA_GROUP_ID=search-service-group

# ── Observabilidade ──────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=search-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
