# apps/auth-service/.env.example
# Copie para .env e preencha os valores

# ── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
SERVICE_NAME=auth-service

# ── Banco de dados (database próprio do serviço) ─────────────────────────────
DATABASE_URL="postgresql://auth_svc:auth_svc_dev@localhost:5432/showpass_auth"

# ── JWT — RS256 (assimétrico)
# Chave PRIVADA: apenas este serviço conhece — assina os tokens
# Chave PÚBLICA: distribuída para todos os serviços — apenas verifica
# NUNCA usar HS256 (simétrico) — comprometer um serviço comprometeria todos
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ── Observabilidade ──────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=auth-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
