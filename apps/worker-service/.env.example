# apps/worker-service/.env.example
# Copie para .env e preencha os valores
#
# ATENÇÃO: worker-service escala VERTICALMENTE (não horizontalmente).
# Puppeteer (Chrome headless) consome ~400MB RAM por instância.
# Não aumentar replicas além do número de partições Kafka do tópico.

# ── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=worker-service
# Sem PORT — worker não expõe HTTP, apenas consome Kafka

# ── Banco de dados (leitura/escrita de tickets) ───────────────────────────────
DATABASE_URL="postgresql://booking_svc:booking_svc_dev@localhost:5432/showpass_booking"

# ── Kafka (consumer) ─────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=worker-service
KAFKA_GROUP_ID=worker-service-group

# ── E-mail (Resend SDK) ──────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@showpass.com

# ── QR Code (HMAC-SHA256) ────────────────────────────────────────────────────
# Chave secreta para assinar QR codes — OWASP A02
# Sem esta chave é impossível forjar um ingresso válido
QR_CODE_SECRET=qr_secret_dev_change_in_production

# ── Observabilidade ──────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=worker-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
