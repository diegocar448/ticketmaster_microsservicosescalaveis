# apps/web/.env.example
# Copie para .env.local e preencha os valores
# Variáveis sem prefixo NEXT_PUBLIC_ são server-side only (SSR)

# ── API Gateway ──────────────────────────────────────────────────────────────
# Server-side: URL interna (dentro da rede Docker)
API_GATEWAY_URL=http://api-gateway:3001
# Client-side: URL pública (browser → load balancer)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Stripe (client-side — somente publishable key) ───────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Next.js ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=nextauth_secret_dev_change_in_production
