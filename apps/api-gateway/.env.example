# apps/api-gateway/.env.example
# Copie para .env e preencha os valores

# ── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
SERVICE_NAME=api-gateway

# ── JWT (chave pública — apenas verificação; emissão é responsabilidade do auth-service) ──
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Redis (rate limiting e fila virtual) ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_secret

# ── URLs internas dos serviços (resolução via DNS do Docker) ─────────────────
AUTH_SERVICE_URL=http://auth-service:3002
EVENT_SERVICE_URL=http://event-service:3003
BOOKING_SERVICE_URL=http://booking-service:3004
PAYMENT_SERVICE_URL=http://payment-service:3005
SEARCH_SERVICE_URL=http://search-service:3006

# ── Observabilidade ──────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=api-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
