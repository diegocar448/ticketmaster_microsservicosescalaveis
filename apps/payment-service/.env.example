# apps/payment-service/.env.example
# Copie para .env e preencha os valores

# ── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
SERVICE_NAME=payment-service

# ── Banco de dados (database próprio do serviço) ─────────────────────────────
DATABASE_URL="postgresql://payment_svc:payment_svc_dev@localhost:5432/showpass_payment"

# ── JWT (chave pública — apenas verificação, webhook não depende de JWT) ─────
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Stripe ───────────────────────────────────────────────────────────────────
# Chave secreta: usar chave de TESTE (sk_test_...) em desenvolvimento.
# NUNCA commitar chaves reais — usar AWS Secrets Manager em produção.
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret: gerado pelo `stripe listen` ou pelo dashboard do Stripe.
# Valida HMAC-SHA256 da assinatura — OWASP A10.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── URLs de serviços (cross-service HTTP) ───────────────────────────────────
# BOOKING_SERVICE_URL é consultado pelo OrdersService para carregar a reserva
# antes de criar a Checkout Session. Em K8s: service discovery via DNS interno.
BOOKING_SERVICE_URL=http://localhost:3004
FRONTEND_URL=http://localhost:3001

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=payment-service
KAFKA_GROUP_ID=payment-service-group
# Consumer group separado do producer — consome auth.buyer-* e auth.organizer-*
# para manter réplicas locais (ver BuyersConsumer / OrganizersConsumer).
KAFKA_CONSUMER_GROUP_ID=payment-service-consumer

# ── Observabilidade ──────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=payment-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
