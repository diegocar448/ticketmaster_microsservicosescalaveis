**/src/prisma/generated/

# Chaves privadas — NUNCA commitar
apps/auth-service/keys/private.pem
apps/auth-service/src/keys/private.key
**/*.pem
**/*.key
!**/*.pub.pem
!**/*.pub.key

# Variáveis de ambiente — apenas .example vai para o repositório
.env
.env.local
.env.*.local
!.env.example

# Turborepo cache
.turbo/

# Logs
*.log
logs/

